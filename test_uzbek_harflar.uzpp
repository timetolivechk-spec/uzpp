// uz++ — o' va g' harflarini to'liq qo'llab-quvvatlash testi

ulash "uzpp_runtime.hpp"
ulash "matematika.hpp"
ulash "matn.hpp"

// -----------------------------------------------
// 1. O'zgaruvchi nomlari o' va g' harflarini o'z ichiga oladi
// -----------------------------------------------
bosh o_harfi_testi() {
    butun o'rtacha_qiymat = 42;
    matn g'oya = "yangi dasturlash g'oyasi";
    matn ro'yxat_nomi = "o'quvchilar ro'yxati";
    haqiqiy o'lchov = 3.14;
    mantiqiy to'g'ri_javob = rost;

    yozish << "O'rtacha: " << o'rtacha_qiymat << qator_oxiri;
    yozish << "G'oya: " << g'oya << qator_oxiri;
    yozish << "Ro'yxat: " << ro'yxat_nomi << qator_oxiri;
    yozish << "O'lchov: " << o'lchov << qator_oxiri;
    yozish << "To'g'ri: " << to'g'ri_javob << qator_oxiri;
}

// -----------------------------------------------
// 2. Funksiya nomi o' harfi bilan
// -----------------------------------------------
butun o'rtacha_hisoblash(butun a, butun b) {
    qaytarish (a + b) / 2;
}

bosh to'g'ri_saralash(vektor<butun>& ro'yxat) {
    uchun (butun i = 0; i < ro'yxat.size() - 1; i++) {
        uchun (butun j = 0; j < ro'yxat.size() - i - 1; j++) {
            agar (ro'yxat[j] > ro'yxat[j + 1]) {
                butun vaqtincha = ro'yxat[j];
                ro'yxat[j] = ro'yxat[j + 1];
                ro'yxat[j + 1] = vaqtincha;
            }
        }
    }
}

// -----------------------------------------------
// 3. Sinf nomi va maydoni o' g' bilan
// -----------------------------------------------
sinf O'quvchi {
ochiq:
    matn to'liq_ism;
    butun o'qish_yili;
    haqiqiy o'rtacha_ball;

    O'quvchi(matn ism, butun yil, haqiqiy ball) : to'liq_ism(ism), o'qish_yili(yil), o'rtacha_ball(ball) {}

    bosh ma'lumot_chiqar() {
        yozish << "O'quvchi: " << to'liq_ism
               << ", " << o'qish_yili << "-yil"
               << ", ball: " << o'rtacha_ball << qator_oxiri;
    }

    mantiqiy a'lochi_mi() {
        qaytarish o'rtacha_ball >= 90.0;
    }
};

// -----------------------------------------------
// 4. o'zgaruvchan kalit so'zi (canonical forma)
// -----------------------------------------------
bosh o_zgaruvchan_testi() {
    o'zgaruvchan son = 100;
    o'zgaruvchan matn_qiymati = matn("salom o'zbekiston!");
    o'zgarmas butun chegara = 255;

    yozish << "Son: " << son << qator_oxiri;
    yozish << "Matn: " << matn_qiymati << qator_oxiri;
    yozish << "Chegara: " << chegara << qator_oxiri;
}

// -----------------------------------------------
// 5. lug'at (g' harfi bilan kalit so'z)
// -----------------------------------------------
bosh lugat_testi() {
    lug'at<matn, butun> o'quvchilar_yoshi;
    o'quvchilar_yoshi["G'ayrat"] = 18;
    o'quvchilar_yoshi["No'mon"] = 19;
    o'quvchilar_yoshi["To'lqin"] = 20;
    o'quvchilar_yoshi["Og'abek"] = 17;

    yozish << "O'quvchilar yoshlari:" << qator_oxiri;
    uchun (o'zgaruvchan& juft : o'quvchilar_yoshi) {
        yozish << "  " << juft.first << ": " << juft.second << qator_oxiri;
    }
}

// -----------------------------------------------
// 6. Shablon funksiya o' harfli parametrlar bilan
// -----------------------------------------------
shablon <tur T>
bosh ro'yxat_chiqar(matn sarlavha, vektor<T>& ro'yxat) {
    yozish << sarlavha << ": [ ";
    uchun (o'zgaruvchan& el : ro'yxat) yozish << el << " ";
    yozish << "]" << qator_oxiri;
}

// -----------------------------------------------
// Asosiy dastur
// -----------------------------------------------
butun asosiy() {
    yozish << "==== o' va g' harflari testi ====" << qator_oxiri << qator_oxiri;

    yozish << "--- 1. O'zgaruvchi nomlari ---" << qator_oxiri;
    o_harfi_testi();

    yozish << qator_oxiri << "--- 2. Funksiyalar ---" << qator_oxiri;
    butun o'rta = o'rtacha_hisoblash(30, 50);
    yozish << "O'rtacha(30, 50) = " << o'rta << qator_oxiri;

    vektor<butun> sonlar = [5, 2, 8, 1, 9, 3, 7];
    to'g'ri_saralash(sonlar);
    ro'yxat_chiqar("Tartiblangan", sonlar);

    yozish << qator_oxiri << "--- 3. Sinf ---" << qator_oxiri;
    O'quvchi o1("G'ayrat Toshmatov", 2, 95.5);
    O'quvchi o2("No'mon Rahimov", 3, 78.0);
    o1.ma'lumot_chiqar();
    o2.ma'lumot_chiqar();
    yozish << "G'ayrat a'lochi: " << (o1.a'lochi_mi() ? "ha" : "yo'q") << qator_oxiri;
    yozish << "No'mon a'lochi: " << (o2.a'lochi_mi() ? "ha" : "yo'q") << qator_oxiri;

    yozish << qator_oxiri << "--- 4. o'zgaruvchan kalit so'zi ---" << qator_oxiri;
    o_zgaruvchan_testi();

    yozish << qator_oxiri << "--- 5. lug'at ---" << qator_oxiri;
    lugat_testi();

    yozish << qator_oxiri << "==== MUVAFFAQIYATLI ===" << qator_oxiri;
    qaytarish 0;
}
