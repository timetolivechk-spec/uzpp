ulash "uzpp_runtime.hpp"

shablon <tur T>
bosh royhat_chiqar(matn sarlavha, vektor<T>& v) {
    yozish << sarlavha << ": [ ";
    uchun (o'zgaruvchan& x : v) yozish << x << " ";
    yozish << "]" << qator_oxiri;
}

shablon <tur T>
T yigindi(vektor<T>& v) {
    T jami = 0;
    uchun (o'zgaruvchan& x : v) jami = jami + x;
    qaytarish jami;
}

butun asosiy() {
    vektor<butun> sonlar = [5, 3, 8, 1, 9, 2, 7, 4, 6];
    royhat_chiqar("Tartiblanmagan", sonlar);
    std::sort(sonlar.begin(), sonlar.end());
    royhat_chiqar("Tartiblangan", sonlar);
    yozish << "Yigindi: " << yigindi(sonlar) << qator_oxiri;

    vektor<matn> ismlar = ["Zafar", "Malika", "Bobur", "Aziz"];
    royhat_chiqar("Tartiblanmagan", ismlar);
    o'zgaruvchan taqqosla = [](matn& a, matn& b) { qaytarish a < b; };
    std::sort(ismlar.begin(), ismlar.end(), taqqosla);
    royhat_chiqar("Tartiblangan", ismlar);

    qaytarish 0;
}
