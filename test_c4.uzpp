ulash "uzpp_runtime.hpp"

shablon <tur T>
bosh royhat_chiqar(matn sarlavha, vektor<T>& v) {
    yozish << sarlavha << ": ";
    uchun (o'zgaruvchan& x : v) yozish << x << " ";
    yozish << qator_oxiri;
}

shablon <tur T>
T yigindi(vektor<T>& v) {
    T jami = 0;
    uchun (o'zgaruvchan& x : v) jami = jami + x;
    qaytarish jami;
}

butun asosiy() {
    vektor<butun> sonlar = [5, 3, 8];
    royhat_chiqar("Sonlar", sonlar);
    yozish << yigindi(sonlar) << qator_oxiri;
    qaytarish 0;
}
