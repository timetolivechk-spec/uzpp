{
    "name": "uzpp",
    "displayName": "uz++",
    "description": "Full IDE support for uz++: syntax highlighting, diagnostics, autocomplete, one-click install.",
    "version": "2.1.8",
    "publisher": "uzpp",
    "engines": { "vscode": "^1.75.0" },
    "categories": ["Programming Languages", "Linters"],
    "keywords": ["uz++", "uzbek", "o'zbek", "programming language", "c++"],
    "repository": {
        "type": "git",
        "url": "https://github.com/timetolivechk-spec/uzpp"
    },
    "bugs":     { "url": "https://github.com/timetolivechk-spec/uzpp/issues" },
    "homepage": "https://github.com/timetolivechk-spec/uzpp#readme",
    "activationEvents": ["onStartupFinished"],
    "main": "./extension.js",
    "contributes": {
        "languages": [
            {
                "id": "uzpp",
                "aliases": ["uz++", "uzpp"],
                "extensions": [".uzpp"],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "uzpp",
                "scopeName": "source.uzpp",
                "path": "./syntaxes/uzpp.tmLanguage.json"
            }
        ],
        "commands": [
            { "command": "uzpp.runFile",             "title": "uz++: Faylni ishga tushirish",             "category": "uz++" },
            { "command": "uzpp.buildFile",           "title": "uz++: Faylni qurish (build)",             "category": "uz++" },
            { "command": "uzpp.formatFile",          "title": "uz++: Faylni formatlash",                 "category": "uz++" },
            { "command": "uzpp.showGeneratedCpp",    "title": "uz++: C++ kodini ko'rish",                "category": "uz++" },
            { "command": "uzpp.newProject",          "title": "uz++: Yangi loyiha yaratish",             "category": "uz++" },
            { "command": "uzpp.installComponents",   "title": "uz++: Komponentlarni o'rnatish",          "category": "uz++" },
            { "command": "uzpp.checkComponents",     "title": "uz++: Komponentlar holati",               "category": "uz++" },
            { "command": "uzpp.uninstallComponents", "title": "uz++: Komponentlarni o'chirish (reset)",  "category": "uz++" },
            { "command": "uzpp.installFromFile",     "title": "uz++: Fayldan o'rnatish (offline)",       "category": "uz++" },
            { "command": "uzpp.updateCompiler",      "title": "uz++: Kompilyatorni yangilash",           "category": "uz++" },
            { "command": "uzpp.openWelcome",         "title": "uz++: Xush kelibsiz ekranini ochish",     "category": "uz++" },
            { "command": "uzpp.restartServer",       "title": "uz++: LSP serverni qayta ishga tushirish","category": "uz++" }
        ],
        "keybindings": [
            { "command": "uzpp.runFile",   "key": "F5",      "when": "editorLangId == uzpp" },
            { "command": "uzpp.buildFile", "key": "ctrl+F5", "when": "editorLangId == uzpp" }
        ],
        "menus": {
            "editor/title/run": [
                { "command": "uzpp.runFile", "when": "editorLangId == uzpp", "group": "navigation" }
            ]
        },
        "configuration": {
            "title": "uz++",
            "properties": {
                "uzpp.compilerPath": {
                    "type": "string",
                    "default": "",
                    "description": "uzpp.exe fayliga to'liq yo'l (ixtiyoriy). Bo'sh bo'lsa, kengaytma globalStorage'dan qidiradi. Ishlab chiquvchilar uchun."
                }
            }
        }
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "scripts": {
        "vscode:prepublish": "echo ready",
        "package": "npx @vscode/vsce package --allow-missing-repository",
        "test": "echo no tests"
    },
    "author": "UzAICoding",
    "license": "MIT"
}
