ulash "uzpp_runtime.hpp"

sinf Nuqta {
ochiq:
    butun x;
    butun y;
    
    Nuqta(butun x_val, butun y_val) {
        x = x_val;
        y = y_val;
    }
    
    Nuqta operator+(Nuqta boshqa) {
        qaytarish Nuqta(x + boshqa.x, y + boshqa.y);
    }
};

butun asosiy() {
    Nuqta a = Nuqta(1, 2);
    Nuqta b = Nuqta(3, 4);
    Nuqta c = a + b;
    yozish << c.x << " " << c.y << qator_oxiri;
    qaytarish 0;
}
