// uz++ — C++17 inline variables on namespace scope

ulash "uzpp_runtime.hpp"

nomlar_fazosi konst {
    qator_ichi o'zgarmas butun MAKS = 1024;
    qator_ichi butun sanoq = 0;
}

butun asosiy() {
    yozish << "MAKS = " << konst::MAKS << qator_oxiri;

    konst::sanoq = konst::sanoq + 1;
    konst::sanoq = konst::sanoq + 1;
    yozish << "sanoq = " << konst::sanoq << qator_oxiri;

    yozish << "=== MUVAFFAQIYATLI ===" << qator_oxiri;
    qaytarish 0;
}
