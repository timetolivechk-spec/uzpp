// uz++ — C++20 range-for with init-statement

ulash "uzpp_runtime.hpp"

vektor<butun> ma'lumotlar() {
    qaytarish {1, 2, 3, 4, 5};
}

butun asosiy() {
    // init: butun jami = 0; range-decl: butun x : ma'lumotlar()
    uchun (butun jami = 0; butun x : ma'lumotlar()) {
        jami = jami + x;
        yozish << "x=" << x << " jami=" << jami << qator_oxiri;
    }

    yozish << "=== MUVAFFAQIYATLI ===" << qator_oxiri;
    qaytarish 0;
}
