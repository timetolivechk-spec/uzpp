// uz++ — Storage classes: static local, thread_local

ulash "uzpp_runtime.hpp"

butun chaqirilgan_marta() {
    statik butun hisoblagich = 0;
    hisoblagich = hisoblagich + 1;
    qaytarish hisoblagich;
}

butun asosiy() {
    yozish << "1-chaqiruv: " << chaqirilgan_marta() << qator_oxiri;
    yozish << "2-chaqiruv: " << chaqirilgan_marta() << qator_oxiri;
    yozish << "3-chaqiruv: " << chaqirilgan_marta() << qator_oxiri;

    yozish << "=== MUVAFFAQIYATLI ===" << qator_oxiri;
    qaytarish 0;
}
