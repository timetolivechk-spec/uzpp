// uz++ — haqiqiy o'zbek so'zlaridagi apostrof (o' / g') o'zgaruvchi,
// funksiya, sinf, metod va maydon nomlarida ishlashini tekshiradi.
// Hammasi C++23 da U+02BC MODIFIER LETTER APOSTROPHE ga aylantirilishi
// kerak — `_` mangling yo'q.

ulash "uzpp_runtime.hpp"

// O'z-o'zini sinash uchun yordamchi
funksiya tekshir(o'zgarmas matn& nom, mantiqiy shart) -> bosh {
    agar (!shart) {
        yozish << "[XATO] " << nom << qator_oxiri;
        irgitish std::runtime_error("Sinov muvaffaqiyatsiz: " + nom);
    }
}

// Apostrof bilan funksiya nomi — "o'lcham" haqiqiy o'zbekcha (size)
funksiya o'lcham(o'zgarmas matn& s) -> hajm_turi {
    qaytarish s.size();
}

// "to'lov" (to'lash dan, payment) — apostrof bilan
funksiya to'lov(butun summa) -> butun {
    qaytarish summa * 2;
}

// Apostrof bilan sinf nomi — "G'oya" (idea)
sinf G'oya {
ochiq:
    matn nomi;
    butun bahosi;

    G'oya(o'zgarmas matn& n, butun b) : nomi(n), bahosi(b) {}

    funksiya yangilash(o'zgarmas matn& n) -> bosh {
        nomi = n;
    }

    funksiya tasviri() o'zgarmas -> matn {
        qaytarish nomi;
    }
};

butun asosiy() {
    // Haqiqiy o'zbek so'zlari lokal o'zgaruvchi nomlari sifatida:
    matn so'z = "salom";       // so'z — word
    butun yo'q = 0;             // yo'q — no/none
    matn ko'k = "rang";         // ko'k — blue
    matn o'rtoq = "do'st";      // o'rtoq — friend; do'st — friend (string)
    butun o'lchov = 42;         // o'lchov — measurement

    tekshir("o'lcham", o'lcham(so'z) == 5);
    tekshir("to'lov", to'lov(50) == 100);
    tekshir("yo'q nol", yo'q == 0);
    tekshir("ko'k rang", ko'k == "rang");
    tekshir("o'rtoq do'st", o'rtoq == "do'st");
    tekshir("o'lchov", o'lchov == 42);

    G'oya g'oya("birinchi", 100);
    tekshir("g'oya.nomi", g'oya.nomi == "birinchi");
    tekshir("g'oya.bahosi", g'oya.bahosi == 100);
    tekshir("g'oya.tasviri()", g'oya.tasviri() == "birinchi");

    g'oya.yangilash("ikkinchi");
    tekshir("g'oya.nomi (yangilangan)", g'oya.nomi == "ikkinchi");

    yozish << "=== MUVAFFAQIYATLI ===" << qator_oxiri;
    qaytarish 0;
}
