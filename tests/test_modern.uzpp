// uz++ — Zamonaviy xususiyatlar testi

ulash "uzpp_runtime.hpp"

butun asosiy() {
    // 1. Formatlangan matn (f-string)
    matn ism = "Antigravity";
    butun yosh = 3;
    yozish << f"Salom, mening ismim {ism} va yoshim {yosh}!" << qator_oxiri;

    // 2. Pattern Matching (Moslash)
    moslash (yosh) {
        holat 0:
            yozish << "Yangi" << qator_oxiri;
        holat 1:
            yozish << "Bir yoshda" << qator_oxiri;
        boshqa:
            yozish << "Katta" << qator_oxiri;
    }

    moslash (ism) {
        holat "Antigravity":
            yozish << "Bu sun'iy intellekt!" << qator_oxiri;
        boshqa:
            yozish << "Oddiy ism" << qator_oxiri;
    }

    // 3. Tanlov<T> (optional/maybe monad)
    Tanlov<butun> qiymatyoq = uzpp::Tanlov<butun>::yoq();
    Tanlov<butun> qiymatbor = uzpp::bor(100);

    yozish << "Bo'sh: " << (qiymatyoq.borMi() ? "bor" : "yo'q") << qator_oxiri;
    yozish << "Qiymat: " << (qiymatbor.borMi() ? "bor" : "yo'q") << qator_oxiri;
    yozish << "Qiymat = " << qiymatbor.qiymat() << qator_oxiri;
    yozish << "Standart = " << qiymatyoq.qiymat_yoki(42) << qator_oxiri;

    // 4. Smart Pointers (Xavfsiz xotira)
    yagona_korsatkich<butun> ptr = yangi_yagona<butun>(42);
    yozish << "Ko'rsatkich qiymati: " << *ptr << qator_oxiri;

    // 5. Natija<T> (Result type)
    uzpp::Natija<butun> muvaffaq = uzpp::Natija<butun>::muvaffaqiyat(99);
    uzpp::Natija<butun> xatolik = uzpp::Natija<butun>::xato("test xato");

    yozish << "Natija: " << (muvaffaq.yaroqliMi() ? "muvaffaq" : "xato") << " = " << muvaffaq.qiymat() << qator_oxiri;
    yozish << "Xato: " << xatolik.xatoMazmun() << qator_oxiri;

    yozish << "=== MUVAFFAQIYATLI ===" << qator_oxiri;
    qaytarish 0;
}
