// uz++ — C++11 decltype(expr) for type deduction

ulash "uzpp_runtime.hpp"

shablon <tur T, tur U>
funksiya qoshish(T a, U b) -> tur_baholash(a + b) {
    qaytarish a + b;
}

butun asosiy() {
    tur_baholash(1 + 2) i = 42;
    yozish << "decltype(1+2) i = " << i << qator_oxiri;

    o'zgaruvchan r1 = qoshish(3, 4);
    yozish << "qoshish(3, 4) = " << r1 << qator_oxiri;

    o'zgaruvchan r2 = qoshish(2.5, 3);
    yozish << "qoshish(2.5, 3) = " << r2 << qator_oxiri;

    yozish << "=== MUVAFFAQIYATLI ===" << qator_oxiri;
    qaytarish 0;
}
