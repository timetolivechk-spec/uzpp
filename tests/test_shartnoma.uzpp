// uz++ — Shartnoma (interfeys) testi

ulash "uzpp_runtime.hpp"

// Shartnoma e'lon qilish
shartnoma Shakl {
    haqiqiy yuzasi();
    haqiqiy perimetri();
}

// Kvadrat sinfi Shakl shartnomasini amalga oshiradi
sinf Kvadrat : Shakl {
ochiq:
    haqiqiy tomon;

    Kvadrat(haqiqiy t) : tomon(t) {}

    haqiqiy yuzasi() {
        qaytarish tomon * tomon;
    }

    haqiqiy perimetri() {
        qaytarish 4.0 * tomon;
    }
}

// Doira sinfi
sinf Doira : Shakl {
ochiq:
    haqiqiy radius;

    Doira(haqiqiy r) : radius(r) {}

    haqiqiy yuzasi() {
        qaytarish 3.14159 * radius * radius;
    }

    haqiqiy perimetri() {
        qaytarish 2.0 * 3.14159 * radius;
    }
}

butun asosiy() {
    Kvadrat k(5.0);
    Doira d(3.0);

    yozish << "=== Shartnoma testi ===" << qator_oxiri;

    yozish << "Kvadrat (tomon=5):" << qator_oxiri;
    yozish << "  Yuzasi:    " << k.yuzasi() << qator_oxiri;
    yozish << "  Perimetri: " << k.perimetri() << qator_oxiri;

    yozish << "Doira (radius=3):" << qator_oxiri;
    yozish << "  Yuzasi:    " << d.yuzasi() << qator_oxiri;
    yozish << "  Perimetri: " << d.perimetri() << qator_oxiri;

    qaytarish 0;
}
