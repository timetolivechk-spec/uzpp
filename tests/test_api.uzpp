// uz++ — API uslubida so'rov-javob testi

ulash "uzpp_runtime.hpp"
ulash "matn.hpp"

sinf ApiJavob {
ochiq:
    butun kod;
    matn xabar;
    matn malumot;

    ApiJavob(butun k, matn x, matn m) : kod(k), xabar(x), malumot(m) {}

    bosh chiqar() {
        yozish << "[" << kod << "] " << xabar << ": " << malumot << qator_oxiri;
    }
}

ApiJavob yonalish_bajar(matn metod, matn yonalish) {
    agar (metod == "GET" && yonalish == "/salom") {
        qaytarish ApiJavob(200, "OK", "Salom, uz++ REST!");
    }
    agar (metod == "GET" && yonalish == "/versiya") {
        qaytarish ApiJavob(200, "OK", "uz++ v2.0");
    }
    qaytarish ApiJavob(404, "Topilmadi", yonalish);
}

butun asosiy() {
    yozish << "=== API test ===" << qator_oxiri;

    vektor<matn> metodlar = ["GET", "GET", "POST"];
    vektor<matn> yonalishlar = ["/salom", "/versiya", "/noma'lum"];

    uchun (butun i = 0; i < 3; i++) {
        yozish << metodlar[i] << " " << yonalishlar[i] << " -> ";
        ApiJavob j = yonalish_bajar(metodlar[i], yonalishlar[i]);
        j.chiqar();
    }

    yozish << "=== MUVAFFAQIYATLI ===" << qator_oxiri;
    qaytarish 0;
}
